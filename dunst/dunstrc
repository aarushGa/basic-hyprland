[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    ### Geometry ###
    width = 350
    height = (0, 300)
    origin = top-right
    offset = (20, 50)
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 10

    ### UI Elements ###
    indicate_hidden = yes
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 15
    
    # Matching the thick border from your image
    frame_width = 3
    # Default frame color (Purple)
    frame_color = "#7600BC"
    
    gap_size = 8
    separator_color = frame
    sort = yes
    idle_threshold = 120

    ### Text & Fonts ###
    font = JetBrainsMono Nerd Font 10
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    
    # Matching the rounded look from your image
    corner_radius = 15
    corners = all
    
    layer = overlay
    force_xwayland = false

    ### Mouse Bindings ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    # Darker background for high contrast with the purple border
    background = "#11111bcc" 
    foreground = "#cdd6f4"
    frame_color = "#7600BC"
    timeout = 5

[urgency_normal]
    background = "#11111bcc"
    foreground = "#cdd6f4"
    frame_color = "#7600BC"
    timeout = 10

[urgency_critical]
    background = "#11111bcc"
    foreground = "#f38ba8"
    frame_color = "#f38ba8" # Keeps red for critical alerts
    timeout = 0